@using CineTracker.Models
@using CineTracker.Services
@using System.Security.Claims
@inject TmdbService TmdbService
@inject WatchlistService WatchlistService
@inject NavigationManager Navigation

@* Tarjeta de película con lógica de autenticación integrada.
   Si el usuario está logueado puede agregar la película a su lista personal.
   Si no lo está, el botón lo redirige a /login. *@
<div class="movie-card" @onclick="GoToDetail">

    @* Imagen del poster. PosterPath viene de la API de TMDB como ruta relativa
       (ej: "/abc123.jpg"). TmdbService.GetImageUrl() le antepone la URL base
       "https://image.tmdb.org/t/p/w500" para formar la URL completa. *@
    @if (!string.IsNullOrEmpty(Movie.PosterPath))
    {
        <img class="movie-poster"
             src="@TmdbService.GetImageUrl(Movie.PosterPath)"
             alt="@Movie.Title"
             loading="lazy" />
    }
    else
    {
        <div class="movie-poster-placeholder">🎬</div>
    }

    <div class="movie-card-body">
        <div class="movie-card-title" title="@Movie.Title">@Movie.Title</div>
        <div class="movie-card-meta">
            @* VoteAverage viene de TMDB: promedio de votos de usuarios (0.0 - 10.0) *@
            <span class="movie-rating">⭐ @Movie.VoteAverage.ToString("F1")</span>
            <span class="movie-year">@GetYear()</span>
        </div>
    </div>

    @* Overlay con botones que aparece al pasar el mouse sobre la tarjeta *@
    <div class="movie-card-overlay">
        <div class="overlay-buttons">

            @* Muestra botones diferentes según si el usuario está autenticado o no *@
            @if (_userId.HasValue)
            {
                @* Usuario logueado: puede agregar a su lista personal *@
                <button class="btn-overlay btn-add" @onclick:stopPropagation="true"
                        @onclick="AddToWatchlist">
                    @* Cambia el texto según si ya está agregada o no *@
                    @(IsAdded ? "✅ Agregada" : "+ Mi Lista")
                </button>
            }
            else
            {
                @* Usuario no logueado: el botón redirige al login en lugar de agregar *@
                <button class="btn-overlay btn-add" @onclick:stopPropagation="true"
                        @onclick="IrAlLogin">
                    🔒 Inicia sesión
                </button>
            }

            <button class="btn-overlay btn-detail" @onclick:stopPropagation="true"
                    @onclick="GoToDetail">
                Ver más
            </button>
        </div>
    </div>
</div>

@code {
    @* Movie: datos de la película que vienen de la API de TMDB.
       El componente padre (Home, Buscar) los pasa como parámetro. *@
    [Parameter] public TmdbMovie Movie { get; set; } = default!;

    @* Callback opcional: el padre puede suscribirse para saber cuándo
       se agrega una película (usado en Home para mostrar el toast). *@
    [Parameter] public EventCallback OnAdded { get; set; }

    @* [CascadingParameter] recibe el estado de autenticación que fue registrado
       globalmente con builder.Services.AddCascadingAuthenticationState() en Program.cs.
       Task<AuthenticationState> es asíncrono porque puede necesitar tiempo para
       verificar la cookie en el servidor. *@
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    // Estado local del componente
    private bool IsAdded = false;  // Indica si esta película ya está en la lista del usuario

    // ID del usuario autenticado extraído de los claims de la cookie.
    // Es nullable: null significa que el usuario no está logueado.
    private int? _userId;

    protected override async Task OnInitializedAsync()
    {
        // Resolvemos el Task para obtener el estado de autenticación actual
        var auth = await AuthStateTask;

        // IsAuthenticated es true si existe una cookie de sesión válida
        if (auth.User.Identity?.IsAuthenticated == true)
        {
            // FindFirst busca el claim de tipo NameIdentifier dentro de la cookie.
            // Lo guardamos como string en el claim, así que lo parseamos a int.
            // Este ID nos permite consultar la base de datos filtrando por usuario.
            var claim = auth.User.FindFirst(ClaimTypes.NameIdentifier);
            if (claim != null)
            {
                _userId = int.Parse(claim.Value);

                // Consulta SQL Server para saber si esta película ya está
                // en la lista de este usuario específico
                IsAdded = await WatchlistService.IsInWatchlistAsync(Movie.Id, _userId.Value);
            }
        }
    }

    /// <summary>
    /// Extrae el año de estreno del formato "YYYY-MM-DD" que devuelve la API de TMDB.
    /// </summary>
    private string GetYear()
    {
        if (string.IsNullOrEmpty(Movie.ReleaseDate)) return "N/A";
        // ReleaseDate viene de TMDB en formato "2023-07-19", tomamos solo los primeros 4 caracteres
        return Movie.ReleaseDate.Length >= 4 ? Movie.ReleaseDate[..4] : "N/A";
    }

    /// <summary>
    /// Agrega la película a la lista personal del usuario en SQL Server.
    /// Solo se ejecuta si el usuario está autenticado (_userId tiene valor).
    /// </summary>
    private async Task AddToWatchlist()
    {
        if (!_userId.HasValue || IsAdded) return;

        // Guarda en SQL Server una copia de los datos de TMDB asociada al usuario
        await WatchlistService.AddToWatchlistAsync(Movie, _userId.Value);
        IsAdded = true;

        // Notifica al componente padre (Home/Buscar) para mostrar el toast
        await OnAdded.InvokeAsync();
    }

    // Redirige al login cuando un usuario no autenticado intenta guardar
    private void IrAlLogin() => Navigation.NavigateTo("/login");

    // Navega a la página de detalle usando el ID de TMDB en la URL
    private void GoToDetail() => Navigation.NavigateTo($"/pelicula/{Movie.Id}");
}
