@inherits LayoutComponentBase

<div class="layout">
    <!-- ===== NAVBAR ===== -->
    <nav class="navbar">
        <!-- Logo / marca de la app -->
        <a href="/" class="navbar-brand">
            CINE<span>Tracker</span>
        </a>

        <!-- Enlaces de navegación principales -->
        <div class="navbar-links">
            <a href="/" class="nav-link">🏠 Inicio</a>
            <a href="/buscar" class="nav-link">🔍 Buscar</a>
            <a href="/mi-lista" class="nav-link">📋 Mi Lista</a>

            <!-- Usuario autenticado: muestra nombre y botón de salir -->
            <AuthorizeView>
                <Authorized>
                    <span class="nav-user">👤 @context.User.Identity?.Name</span>
                    <a href="/logout" class="nav-link nav-logout">Salir</a>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="nav-link">Iniciar sesión</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </nav>

    <!-- ===== CONTENIDO PRINCIPAL ===== -->
    <main>
        @Body
    </main>
</div>

